<table align="center">
<tr><td colspan="2" align="center"  style="background: #5D7B9D; font-weight:bold; color:White">
    <asp:Label ID="Label2" runat="server" Font-Bold="True" Font-Size="Small" Text="Systems Registration"></asp:Label></td></tr>
<tr><td>
    <asp:Label ID="Label1" runat="server" Text="System"></asp:Label></td><td>
        <asp:TextBox ID="TxtBoxSystem" runat="server" MaxLength="50" Width="275px"></asp:TextBox></td></tr>
