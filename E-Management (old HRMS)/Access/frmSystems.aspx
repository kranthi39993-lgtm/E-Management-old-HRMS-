        deletecommand="Sp_DelSystems" DeleteCommandType="StoredProcedure">
        <DeleteParameters>
            <asp:Parameter Name="SystemName" Type="String" />
        </DeleteParameters>
        
    </asp:SqlDataSource></td></tr>
